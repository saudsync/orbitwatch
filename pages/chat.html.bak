<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AI Astronomer — OrbitWatch</title>
<link rel="stylesheet" href="../css/style.css"/>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet"/>
<style>
  .api-key-banner {
    background: rgba(123,97,255,.1); border: 1px solid rgba(123,97,255,.3);
    border-radius: 10px; padding: 14px 18px; margin: 0 24px 12px;
    font-size: 12px; color: var(--accent2);
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .api-key-banner input {
    flex: 1; min-width: 200px; background: var(--surface2);
    border: 1px solid rgba(123,97,255,.3); border-radius: 6px;
    color: var(--text); font-family: var(--font-mono); font-size: 12px;
    padding: 7px 12px; outline: none; transition: border-color .2s;
  }
  .api-key-banner input:focus { border-color: var(--accent2); }
  .api-key-btn {
    background: var(--accent2); color: #fff; border: none; border-radius: 6px;
    padding: 7px 14px; font-size: 12px; font-family: var(--font-mono); cursor: pointer; transition: opacity .2s;
  }
  .api-key-btn:hover { opacity: .85; }
  .api-key-clear {
    background: none; border: 1px solid rgba(255,69,96,.3); color: var(--red);
    border-radius: 6px; padding: 7px 12px; font-size: 11px;
    font-family: var(--font-mono); cursor: pointer; transition: all .2s;
  }
  .api-key-clear:hover { background: rgba(255,69,96,.1); }
  .api-status { font-size: 11px; }
  .api-status.ok  { color: var(--green); }
  .api-status.err { color: var(--red); }
  .msg-time { font-size: 10px; color: var(--muted); margin-top: 4px; text-align: right; }
  .chat-msg.ai .msg-time { text-align: left; }
  .fact-chip {
    display: inline-block; background: rgba(0,212,255,.08);
    border: 1px solid rgba(0,212,255,.15); border-radius: 8px;
    padding: 6px 12px; font-size: 11px; color: var(--accent);
    margin: 4px; cursor: pointer; transition: all .2s;
  }
  .fact-chip:hover { background: rgba(0,212,255,.18); }
  .empty-state {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; flex: 1; gap: 12px; padding: 40px;
  }
  .empty-icon  { font-size: 64px; opacity: .6; }
  .empty-title { font-family: var(--font-display); font-size: 22px; font-weight: 700; }
  .empty-sub   { color: var(--muted); font-size: 13px; text-align: center; max-width: 380px; line-height: 1.7; }
  .model-badge {
    font-size: 10px; padding: 3px 9px; border-radius: 10px;
    background: rgba(0,255,157,.08); border: 1px solid rgba(0,255,157,.2);
    color: var(--green); font-family: var(--font-mono); margin-top: 3px; display: inline-block;
  }
  .msg-bubble.error {
    border-color: rgba(255,69,96,.35) !important;
    background: rgba(255,69,96,.06) !important;
    color: #ff8090 !important;
  }
</style>
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <a href="../index.html" class="logo"><span class="logo-dot"></span>Orbit<span class="logo-light">Watch</span></a>
    <nav class="site-nav">
      <a href="../index.html" class="nav-link">Home</a>
      <a href="tracker.html" class="nav-link">Tracker</a>
      <a href="database.html" class="nav-link">Database</a>
      <a href="chat.html" class="nav-link nav-ai active">🤖 AI Chat</a>
    </nav>
    <div class="live-badge"><span class="live-dot"></span>LIVE</div>
    <button class="mobile-menu-btn" id="mobileMenuBtn">☰</button>
  </div>
  <div class="mobile-nav" id="mobileNav">
    <a href="../index.html" class="nav-link">Home</a>
    <a href="tracker.html" class="nav-link">Tracker</a>
    <a href="database.html" class="nav-link">Database</a>
    <a href="chat.html" class="nav-link active">🤖 AI Chat</a>
  </div>
</header>

<div class="chat-page">

  <div class="chat-header">
    <div class="chat-avatar">🔭</div>
    <div>
      <div class="chat-agent-name">ARIA — Astronomy &amp; Space AI</div>
      <div class="chat-agent-status"><span class="live-dot"></span><span id="agentStatus">Ready to explore the cosmos</span></div>
      <span class="model-badge" id="modelBadge">Ollama · Local AI</span>
    </div>
    <button id="clearChat" style="margin-left:auto;background:none;border:1px solid var(--border);color:var(--muted);border-radius:6px;padding:6px 12px;font-size:11px;font-family:var(--font-mono);transition:all .2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--muted)'">Clear Chat</button>
  </div>

  <div class="api-key-banner" id="apiBanner">
    <span>🔑 Enter your <strong>Ollama API key</strong> from <a href="https://ollama.com/settings/keys" target="_blank" style="color:var(--accent)">ollama.com/settings/keys</a>:</span>
    <input type="password" id="apiKeyInput" placeholder="ollama_…"/>
    <button class="api-key-btn" id="saveApiKey">Save Key</button>
    <button class="api-key-clear" id="clearApiKey" style="display:none">Remove</button>
    <span class="api-status err" id="apiStatus">No key — demo mode</span>
  </div>

  <div class="chat-body" id="chatBody">
    <div class="empty-state" id="emptyState">
      <div class="empty-icon">🌌</div>
      <div class="empty-title">Ask ARIA Anything About Space</div>
      <div class="empty-sub">Powered by <strong>Ollama</strong> — local AI. Ask about satellites, black holes, ISRO missions, orbital mechanics and more.</div>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:6px;margin-top:12px">
        <span class="fact-chip" onclick="askSuggestion(this)">How does the ISS orbit Earth?</span>
        <span class="fact-chip" onclick="askSuggestion(this)">What is orbital velocity?</span>
        <span class="fact-chip" onclick="askSuggestion(this)">Explain Starlink satellites</span>
        <span class="fact-chip" onclick="askSuggestion(this)">What is a geostationary orbit?</span>
        <span class="fact-chip" onclick="askSuggestion(this)">How do satellites de-orbit?</span>
        <span class="fact-chip" onclick="askSuggestion(this)">Tell me about black holes</span>
        <span class="fact-chip" onclick="askSuggestion(this)">Tell me about CARTOSAT-2F</span>
        <span class="fact-chip" onclick="askSuggestion(this)">What is NavIC IRNSS?</span>
      </div>
    </div>
  </div>

  <div class="chat-suggestions" id="suggestionRow">
    <button class="suggestion-chip" onclick="askSuggestion(this)">🛸 What is the ISS made of?</button>
    <button class="suggestion-chip" onclick="askSuggestion(this)">🌑 How far is the Moon?</button>
    <button class="suggestion-chip" onclick="askSuggestion(this)">🇮🇳 Tell me about CARTOSAT-2F</button>
    <button class="suggestion-chip" onclick="askSuggestion(this)">🧭 What is NavIC / IRNSS?</button>
    <button class="suggestion-chip" onclick="askSuggestion(this)">🚀 ISRO greatest achievements</button>
    <button class="suggestion-chip" onclick="askSuggestion(this)">⭐ What is a neutron star?</button>
  </div>

  <div class="chat-input-row">
    <textarea class="chat-input" id="chatInput" placeholder="Ask about satellites, orbits, astronomy, space missions…" rows="1"></textarea>
    <button class="chat-send" id="sendBtn" title="Send">➤</button>
  </div>

</div>

<script src="../js/satellites.js"></script>
<script>
/* ═══════════════════════════════════════════════════
   ORBITWATCH · ARIA — Ollama backend
   Uses Ollama cloud API (openai-compatible endpoint)
   Model: llama3 (or any model available on your account)
   ═══════════════════════════════════════════════════ */

const OLLAMA_ENDPOINT = 'https://api.ollama.com/v1/chat/completions';
const OLLAMA_MODEL    = 'llama3.2';
const MAX_TOKENS      = 1024;
const MAX_HISTORY     = 20;

const SAT_LIST = (typeof SATELLITES !== 'undefined')
  ? SATELLITES.map(s => s.name + ' (NORAD ' + s.norad + ')').join(', ')
  : 'ISS, Hubble, Tiangong, Starlink, CARTOSAT-2F, IRNSS-1I NavIC, and more';

const SYSTEM_PROMPT = `You are ARIA (Astronomy & Research Intelligence Agent), an expert AI astronomer for the OrbitWatch satellite tracking platform.

Expertise:
- Satellite orbital mechanics, TLE data, SGP4 propagation
- Space missions: ISS, Hubble, Starlink, NASA, ESA, SpaceX, Roscosmos, JAXA
- ISRO missions: PSLV, GSLV, Chandrayaan-1/2/3, Mangalyaan, NavIC, CARTOSAT, RISAT, Aditya-L1, Gaganyaan
- Astronomy: galaxies, stars, black holes, nebulae, exoplanets
- Rocket science, re-entry physics, Hohmann transfers
- Earth observation and remote sensing

OrbitWatch tracks: ${SAT_LIST}

Indian satellites:
- CARTOSAT-2F (43111): ISRO high-res Earth imaging, PSLV-C40, Jan 2018
- IRNSS-1I / NavIC (43286): India navigation system, PSLV-C41, Apr 2018

Style: Enthusiastic, clear, educational. Bold key terms using **term**. Keep answers 2-4 paragraphs. Show pride in ISRO. End with a curious follow-up question.`;

let ollamaApiKey = localStorage.getItem('ow_ollama_key') || '';
let conversationHistory = [];
let isLoading = false;

// ── KEY UI ────────────────────────────────────────────────────────────────────
function updateKeyUI() {
  const banner = document.getElementById('apiBanner');
  const status = document.getElementById('apiStatus');
  const clearBtn = document.getElementById('clearApiKey');
  const badge = document.getElementById('modelBadge');
  const agentSt = document.getElementById('agentStatus');

  if (ollamaApiKey) {
    banner.style.cssText += 'background:rgba(0,255,157,.05);border-color:rgba(0,255,157,.2);';
    status.textContent = '✓ Ollama key active — full AI mode';
    status.className = 'api-status ok';
    clearBtn.style.display = 'inline-block';
    badge.textContent = 'Ollama · ' + OLLAMA_MODEL + ' · Active ✓';
    badge.style.background = 'rgba(0,255,157,.1)';
    agentSt.textContent = 'Online — Ollama powered';
  } else {
    banner.style.cssText += 'background:rgba(123,97,255,.1);border-color:rgba(123,97,255,.3);';
    status.textContent = 'No key — demo mode';
    status.className = 'api-status err';
    clearBtn.style.display = 'none';
    badge.textContent = 'Demo mode — add Ollama key';
    badge.style.background = 'rgba(255,140,66,.08)';
    agentSt.textContent = 'Demo mode — add Ollama key to activate';
  }
}

document.getElementById('saveApiKey').addEventListener('click', () => {
  const val = document.getElementById('apiKeyInput').value.trim();
  const status = document.getElementById('apiStatus');
  if (!val) { status.textContent = '✗ Please enter a key'; status.className = 'api-status err'; return; }
  ollamaApiKey = val;
  localStorage.setItem('ow_ollama_key', val);
  document.getElementById('apiKeyInput').value = '';
  status.textContent = '✓ Saved! Connecting…'; status.className = 'api-status ok';
  updateKeyUI();
});

document.getElementById('clearApiKey').addEventListener('click', () => {
  ollamaApiKey = ''; localStorage.removeItem('ow_ollama_key'); updateKeyUI();
});

// ── OLLAMA API ────────────────────────────────────────────────────────────────
async function callOllama(userText) {
  const messages = [
    { role: 'system', content: SYSTEM_PROMPT },
    ...conversationHistory.slice(-MAX_HISTORY),
    { role: 'user', content: userText }
  ];

  const res = await fetch(OLLAMA_ENDPOINT, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + ollamaApiKey },
    body: JSON.stringify({ model: OLLAMA_MODEL, max_tokens: MAX_TOKENS, temperature: 0.7, messages })
  });

  let data;
  try { data = await res.json(); } catch(_) { throw new Error('Non-JSON response from server (HTTP ' + res.status + ')'); }

  if (!res.ok) {
    throw new Error(data?.error?.message || data?.error?.code || 'API error ' + res.status);
  }

  const reply = data?.choices?.[0]?.message?.content?.trim();
  if (!reply) throw new Error('Empty response received. Please try again.');
  return reply;
}

// ── ERROR MAPPER ──────────────────────────────────────────────────────────────
function friendlyError(msg) {
  if (!msg) return 'Unknown error — please retry.';
  const m = msg.toLowerCase();
  if (m.includes('401') || m.includes('invalid api key') || m.includes('unauthorized'))
    return 'Invalid Ollama API key. Get yours at ollama.com/settings/keys and update above.';
  if (m.includes('429') || m.includes('rate limit') || m.includes('quota'))
    return 'Rate limit reached. Wait 30 seconds and retry.';
  if (m.includes('404') || m.includes('model'))
    return 'Model temporarily unavailable. Please retry in a moment.';
  if (m.includes('fetch') || m.includes('network') || m.includes('cors'))
    return 'Network error. Please check your internet connection.';
  if (m.includes('context') || m.includes('token'))
    return 'Message history too long — clearing context. Please repeat your question.';
  return msg.length > 100 ? msg.slice(0, 100) + '…' : msg;
}

// ── DEMO RESPONSES ────────────────────────────────────────────────────────────
const DEMO = [
  "I'd love to give a full answer! Add your **Ollama API key** above (get it at ollama.com/settings/keys).\n\n**Quick fact:** The ISS orbits at ~408 km altitude at 7.66 km/s — completing one orbit every 92 minutes, giving astronauts 16 sunrises per day! 🌅\n\nWhat are you curious about?",
  "Add your **Ollama key** above to unlock live AI answers!\n\n**Space fact:** Geostationary satellites orbit at exactly **35,786 km** where their speed matches Earth's rotation — appearing to hover perfectly still over one spot. This is why your TV dish always points the same direction! 📡\n\nWhat else would you like to explore?",
  "Almost there — just need your **Ollama API key** to power full answers!\n\n**ISRO fact:** India's NavIC system (IRNSS-1I on OrbitWatch) is India's own GPS — covering the entire subcontinent plus 1,500 km beyond its borders. Only the US, Russia, EU, China and Japan also have independent navigation systems. India joined this elite club! 🇮🇳\n\nAdd your key and I'll answer anything!",
];
let demoIdx = 0;

// ── RENDERING ─────────────────────────────────────────────────────────────────
function hideEmpty() { document.getElementById('emptyState')?.remove(); }

function formatMessage(text) {
  return text
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.*?)\*/g,'<em>$1</em>')
    .replace(/`(.*?)`/g,'<code style="background:rgba(0,212,255,.1);padding:1px 5px;border-radius:3px;font-size:11px">$1</code>')
    .replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br/>')
    .replace(/^(.*)$/,'<p>$1</p>');
}

function addMessage(role, content, isError) {
  hideEmpty();
  const body = document.getElementById('chatBody');
  const div = document.createElement('div');
  div.className = 'chat-msg ' + role;
  const t = new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  div.innerHTML = `
    <div class="msg-avatar ${role}">${role==='ai'?'🔭':'👤'}</div>
    <div style="max-width:100%">
      <div class="msg-bubble${isError?' error':''}">${formatMessage(content)}</div>
      <div class="msg-time">${t}</div>
    </div>`;
  body.appendChild(div);
  body.scrollTop = body.scrollHeight;
}

function addTyping() {
  hideEmpty();
  const body = document.getElementById('chatBody');
  const div = document.createElement('div');
  div.className = 'chat-msg ai'; div.id = 'typing-indicator';
  div.innerHTML = '<div class="msg-avatar ai">🔭</div><div class="msg-bubble"><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>';
  body.appendChild(div); body.scrollTop = body.scrollHeight;
}
function removeTyping() { document.getElementById('typing-indicator')?.remove(); }

function setLoading(on) {
  isLoading = on;
  document.getElementById('sendBtn').disabled = on;
  document.getElementById('agentStatus').textContent = on
    ? 'ARIA is thinking…'
    : (ollamaApiKey ? 'Online — Ollama powered' : 'Demo mode — add Ollama key to activate');
}

// ── SEND ──────────────────────────────────────────────────────────────────────
async function sendMessage(text) {
  text = (text || '').trim();
  if (!text || isLoading) return;
  setLoading(true);
  addMessage('user', text);
  addTyping();

  if (!ollamaApiKey) {
    await new Promise(r => setTimeout(r, 900 + Math.random() * 600));
    removeTyping();
    const reply = DEMO[demoIdx++ % DEMO.length];
    addMessage('ai', reply);
    conversationHistory.push({role:'user',content:text},{role:'assistant',content:reply});
    setLoading(false);
    return;
  }

  try {
    const reply = await callOllama(text);
    removeTyping();
    addMessage('ai', reply);
    conversationHistory.push({role:'user',content:text},{role:'assistant',content:reply});
    if (conversationHistory.length > MAX_HISTORY * 2) conversationHistory = conversationHistory.slice(-MAX_HISTORY);
  } catch(err) {
    removeTyping();
    console.error('[ARIA Ollama Error]', err);
    const friendly = friendlyError(err.message);
    if (err.message.toLowerCase().includes('context') || err.message.toLowerCase().includes('token')) {
      conversationHistory = [];
    }
    addMessage('ai', '⚠️ ' + friendly, true);
  }
  setLoading(false);
}

function askSuggestion(el) {
  const raw = el.textContent || '';
  const text = raw.replace(/^[\s\S]*?([A-Za-z0-9\u0900-\u097F])/, '$1').trim() || raw.trim();
  document.getElementById('chatInput').value = text;
  sendAndClear();
}

function sendAndClear() {
  const inp = document.getElementById('chatInput');
  const text = inp.value.trim();
  if (!text) return;
  inp.value = ''; inp.style.height = 'auto';
  sendMessage(text);
}

document.getElementById('sendBtn').addEventListener('click', sendAndClear);
document.getElementById('chatInput').addEventListener('keydown', e => { if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendAndClear();} });
document.getElementById('chatInput').addEventListener('input', function(){ this.style.height='auto'; this.style.height=Math.min(this.scrollHeight,120)+'px'; });

document.getElementById('clearChat').addEventListener('click', () => {
  conversationHistory = [];
  document.getElementById('chatBody').innerHTML = '<div class="empty-state" id="emptyState"><div class="empty-icon">🌌</div><div class="empty-title">Ask ARIA Anything About Space</div><div class="empty-sub">Powered by <strong>Ollama</strong>. Ask about satellites, ISRO, black holes and more.</div><div style="display:flex;flex-wrap:wrap;justify-content:center;gap:6px;margin-top:12px"><span class="fact-chip" onclick="askSuggestion(this)">How does the ISS orbit Earth?</span><span class="fact-chip" onclick="askSuggestion(this)">What is orbital velocity?</span><span class="fact-chip" onclick="askSuggestion(this)">Tell me about CARTOSAT-2F</span><span class="fact-chip" onclick="askSuggestion(this)">What is NavIC IRNSS?</span></div></div>';
});

document.getElementById('mobileMenuBtn')?.addEventListener('click', () => document.getElementById('mobileNav')?.classList.toggle('open'));

updateKeyUI();

setTimeout(() => {
  const satCount = (typeof SATELLITES !== 'undefined') ? SATELLITES.length : 14;
  const mode = ollamaApiKey ? '**Ollama** is fully active' : 'in **demo mode** (add your Ollama key above to unlock)';
  addMessage('ai', `Hello! I\'m **ARIA**, your AI astronomy guide on OrbitWatch 🌌\n\nCurrently running ${mode}. I can answer questions about **satellites, orbital mechanics, space missions, ISRO, astronomy**, and anything cosmic.\n\nTracking **${satCount} satellites** — including ISS, Hubble, Tiangong, CARTOSAT-2F 🇮🇳, and NavIC/IRNSS-1I 🇮🇳.\n\nWhat would you like to explore today? 🚀`);
}, 400);
</script>
</body>
</html>
